# Скопируйте этот файл в .env и заполните значения. .env в git НЕ коммитим.

# Токен MAX-бота от @MasterBot
MAX_BOT_TOKEN=

# Канал для подписки: ссылка идёт на кнопку «Подписаться» и используется,
# чтобы определить числовой ID канала автоматически.
MAX_CHANNEL_LINK=https://max.ru/id773126457242_biz

# Необязательно: числовой ID канала. Пусто -> определится из ссылки при старте.
MAX_CHANNEL_ID=

# Тексты (одной строкой)
MAX_LEAD_MAGNET_TEXT=Спасибо за подписку! 🎉 Вот твой эксклюзивный документ: clck.ru/3UJyuy — открывай и скачивай. Приятного изучения!
MAX_WELCOME_TEXT=Привет! 👋 Для получения гайда "10 проверенных маркетинговых стратегий" подпишись на канал "Сорокин в Маркетинге"
MAX_NOT_SUBSCRIBED_TEXT=Кажется, подписки пока нет 🤔 Подпишись на канал и нажми «Я подписался ✅» ещё раз.
