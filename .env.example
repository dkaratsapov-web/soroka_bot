# Скопируйте этот файл в .env и заполните значения.
# .env коммитить в git НЕЛЬЗЯ.

# Токен бота от @BotFather (создаётся командой /newbot)
BOT_TOKEN=

# Канал для подписки (публичный, юзернейм со знаком @)
CHANNEL=@sorokavmarketinge

# Ссылка для кнопки «Подписаться»
CHANNEL_URL=https://t.me/sorokavmarketinge

# Картинка к первому сообщению. Файл welcome.jpg уже лежит в папке проекта.
# Пусто -> приветствие отправится без картинки.
WELCOME_IMAGE=welcome.jpg

# Файл лид-магнита (необязательно). У нас гайд отдаётся ссылкой, поэтому оставляем пустым.
LEAD_MAGNET_FILE=

# Тексты по умолчанию уже зашиты в код (точно по ТЗ).
# Переопределять здесь нужно, только если захотите поменять формулировки:
# WELCOME_TEXT=
# LEAD_MAGNET_TEXT=
# NOT_SUBSCRIBED_TEXT=
