# Скопируйте этот файл в .env и заполните значения.
# .env коммитить в git НЕЛЬЗЯ.

# Токен бота от @BotFather
BOT_TOKEN=

# Канал для подписки.
# Публичный: @my_channel | Приватный: числовой ID вида -1001234567890
CHANNEL=@sorokavmarketinge

# Ссылка для кнопки «Подписаться».
# Публичный: https://t.me/my_channel | Приватный: пригласительная ссылка https://t.me/+xxxx
CHANNEL_URL=https://t.me/sorokavmarketinge

# Лид-магнит: путь к файлу (необязательно). Пусто -> уйдёт только текст.
LEAD_MAGNET_FILE=

# Текст, который получает подписчик (можно со ссылкой на вебинар/гайд)
LEAD_MAGNET_TEXT=Спасибо за подписку! 🎉 Вот ваш материал: https://example.com/your-link
